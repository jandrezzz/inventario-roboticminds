<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Dashboard — Robotic Minds Inventario</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>

  <%# ── NAVBAR ─────────────────────────────────────────────────────────────── %>
  <nav class="navbar">
    <div class="navbar-marca">
      <span>⚙️ Robotic Minds</span>
      <small>Inventario</small>
    </div>
    <div class="navbar-usuario">
      <%# Mostramos nombre y rol del usuario en sesión %>
      <span class="badge badge-<%= usuario.rol === 'administrador' ? 'admin' : 'operador' %>">
        <%= usuario.rol %>
      </span>
      <span class="navbar-nombre"><%= usuario.nombre %></span>
      <a href="/logout" class="btn btn-outline btn-sm">Cerrar Sesión</a>
    </div>
  </nav>

  <%# ── CONTENIDO PRINCIPAL ─────────────────────────────────────────────────── %>
  <main class="contenido">

    <%# Mensaje flash (éxito / error) guardado en sesión tras una acción %>
    <% if (mensaje) { %>
      <div class="alerta alerta-<%= mensaje.tipo %>">
        <%= mensaje.texto %>
      </div>
    <% } %>

    <%# ── SECCIÓN: ALERTAS DE BAJO STOCK ────────────────────────────────────── %>
    <% if (bajoStock.length > 0) { %>
      <section class="seccion">
        <h2 class="seccion-titulo alerta-titulo">
          ⚠️ Alertas de Stock Bajo (<%= bajoStock.length %>)
        </h2>
        <table class="tabla tabla-alertas">
          <thead>
            <tr>
              <th>Componente</th>
              <th>Categoría</th>
              <th>En Existencia</th>
              <th>Mínimo Requerido</th>
              <th>Faltante</th>
            </tr>
          </thead>
          <tbody>
            <% bajoStock.forEach(comp => { %>
              <tr class="fila-alerta">
                <td><strong><%= comp.nombre %></strong></td>
                <td><%= comp.categoria || '—' %></td>
                <td class="cantidad-baja"><%= comp.cantidad %></td>
                <td><%= comp.stock_minimo %></td>
                <%# Calculamos en la vista cuántas unidades faltan %>
                <td class="faltante"><%= comp.stock_minimo - comp.cantidad %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </section>
    <% } %>

    <%# ── SECCIÓN: INVENTARIO COMPLETO ──────────────────────────────────────── %>
    <section class="seccion">
      <div class="seccion-cabecera">
        <h2 class="seccion-titulo">Inventario de Componentes</h2>
        <%# Botón "Nuevo Componente" solo visible para administradores %>
        <% if (usuario.rol === 'administrador') { %>
          <a href="/componentes/nuevo" class="btn btn-primario">+ Nuevo Componente</a>
        <% } %>
      </div>

      <% if (componentes.length === 0) { %>
        <p class="sin-datos">No hay componentes registrados.</p>
      <% } else { %>
        <table class="tabla">
          <thead>
            <tr>
              <th>#</th>
              <th>Nombre</th>
              <th>Categoría</th>
              <th>Cantidad</th>
              <th>Stock Mín.</th>
              <th>Precio Unit.</th>
              <th>Fecha Alta</th>
              <%# Columna de acciones solo si es administrador %>
              <% if (usuario.rol === 'administrador') { %>
                <th>Acciones</th>
              <% } %>
            </tr>
          </thead>
          <tbody>
            <% componentes.forEach(comp => { %>
              <%# Resaltamos filas con stock bajo usando clase CSS especial %>
              <tr class="<%= comp.cantidad < comp.stock_minimo ? 'fila-alerta' : '' %>">
                <td><%= comp.id %></td>
                <td><%= comp.nombre %></td>
                <td><%= comp.categoria || '—' %></td>
                <td class="<%= comp.cantidad < comp.stock_minimo ? 'cantidad-baja' : '' %>">
                  <%= comp.cantidad %>
                </td>
                <td><%= comp.stock_minimo %></td>
                <td>$<%= parseFloat(comp.precio_unitario).toFixed(2) %></td>
                <td><%= new Date(comp.fecha_creacion).toLocaleDateString('es-MX') %></td>
                <%# Botones editar/eliminar solo para administrador %>
                <% if (usuario.rol === 'administrador') { %>
                  <td class="acciones">
                    <a href="/componentes/<%= comp.id %>/editar" class="btn btn-secundario btn-sm">
                      Editar
                    </a>
                    <form
                      action="/componentes/<%= comp.id %>/eliminar"
                      method="POST"
                      style="display:inline"
                      onsubmit="return confirm('¿Eliminar este componente? Esta acción no se puede deshacer.')"
                    >
                      <button type="submit" class="btn btn-peligro btn-sm">Eliminar</button>
                    </form>
                  </td>
                <% } %>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

    <%# ── SECCIÓN: HISTORIAL DE MOVIMIENTOS — accesible para ambos roles ─────── %>
    <section class="seccion">
      <h2 class="seccion-titulo">Historial de Movimientos</h2>

      <% if (historial.length === 0) { %>
        <p class="sin-datos">No hay movimientos registrados todavía.</p>
      <% } else { %>
        <table class="tabla">
          <thead>
            <tr>
              <th>#</th>
              <th>Componente</th>
              <th>Cantidad Resultante</th>
              <th>Acción</th>
              <th>Fecha y Hora</th>
            </tr>
          </thead>
          <tbody>
            <% historial.forEach(mov => { %>
              <tr>
                <td><%= mov.id %></td>
                <td><%= mov.componente %></td>
                <td><%= mov.cantidad_modificada %></td>
                <td><span class="tag-accion"><%= mov.accion %></span></td>
                <td><%= new Date(mov.fecha_hora).toLocaleString('es-MX') %></td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      <% } %>
    </section>

  </main>

  <footer class="footer">
    <p>Robotic Minds &copy; <%= new Date().getFullYear() %> — Sistema de Inventario</p>
  </footer>

</body>
</html>
